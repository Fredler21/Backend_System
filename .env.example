# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://edlight_user:edlight_pass@localhost:5432/edlight_db

# Authentication
JWT_SECRET=your-super-secure-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secure-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Encryption
BCRYPT_SALT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Admin Invite
ADMIN_INVITE_EXPIRY_HOURS=24
ADMIN_ALLOWED_EMAILS=admin@edlight.org,info@edlight.org
ADMIN_PANEL_URL=http://localhost:3001

# Firebase Migration (only needed when running migration scripts)
# Download from: Firebase Console → Project Settings → Service Accounts → Generate Key
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Migration Options
MIGRATION_DOWNLOAD_FILES=false
MIGRATION_DOWNLOAD_DIR=./migration-downloads
STORAGE_DRIVER=local
