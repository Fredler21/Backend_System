{
  "name": "@edlight/backend-system",
  "version": "1.0.0",
  "description": "Core backend infrastructure for the Edlight Initiative educational platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx src/database/seed.ts",
    "prisma:studio": "prisma studio",
    "migrate:auth": "tsx src/migrations/migrate.ts auth",
    "migrate:users": "tsx src/migrations/migrate.ts users",
    "migrate:profiles": "tsx src/migrations/migrate.ts profiles",
    "migrate:courses": "tsx src/migrations/migrate.ts courses",
    "migrate:scholarships": "tsx src/migrations/migrate.ts scholarships",
    "migrate:posts": "tsx src/migrations/migrate.ts posts",
    "migrate:activity_logs": "tsx src/migrations/migrate.ts activity_logs",
    "migrate:files": "tsx src/migrations/migrate.ts files",
    "migrate:all": "tsx src/migrations/migrate.ts all",
    "migrate:all:dry": "tsx src/migrations/migrate.ts all --dry-run"
  },
  "prisma": {
    "seed": "tsx src/database/seed.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fredler21/Backend_System.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Fredler21/Backend_System/issues"
  },
  "homepage": "https://github.com/Fredler21/Backend_System#readme",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
