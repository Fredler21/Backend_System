{
  "version": 2,
  "builds": [
    {
      "src": "admin/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "/health",
      "dest": "api/index.ts"
    },
    {
      "src": "/readiness",
      "dest": "api/index.ts"
    },
    {
      "src": "/metrics",
      "dest": "api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "admin/$1"
    }
  ]
}
